{
  "avant-depart": {
    "title": "Avant le départ",
    "sections": [
      {
        "heading": "Nous invitons la, le ou les pilotes à se renseigner sur l'état de son groupe en posant les questions suivantes.",
        "items": [
          "Êtes-vous bien équipés ?",
          "Vos chaussures sont-elles adaptées ?",
          "Avez-vous suffisamment d’eau ?",
          "Avez-vous assez à manger ?",
          "Avez-vous bien évalué votre condition physique ?",
          "Avez-vous des problèmes de santé notoires à signaler ?"
        ]
      },
      {
        "heading": "Protégeons la nature",
        "items": [
          "Si vous trouvez des déchets sauvages, nous vous invitons à les ramasser si possible. Pour les volontaires, des sacs poubelles sont disponibles.",
          "Applications pour signaler les décharges sauvages :",
          "Trash Spotter",
          "Clean 4 Green",
          "Merci à vous !"
        ]
      }
    ]
  },
  "accident": {
    "title": "En cas d'accident",
    "sections": [
      {
        "heading": "Premiers gestes :",
        "items": [
          "Sécuriser la zone (éviter un sur-accident)",
          "Évaluer l'état de la personne",
          "Ne pas déplacer la victime sauf danger immédiat",
          "Rassurer et couvrir la personne"
        ]
      },
      {
        "heading": "Prévenir les urgences :",
        "items": [
          "Numéro européen : 112",
          "SAMU : 15",
          "Sapeurs-pompiers : 18",
          "Alerte par SMS : 114",
          "Alerte Secours"
        ]
      },
      {
        "heading": "Informer :",
        "items": [
          "Localisation précise (point GPS, chemin, repère)",
          "Nombre de blessé.e.s",
          "État de la victime (consciente, respiration, saignement)",
          "Nature de l'accident (chute, malaise, entorse, etc.)"
        ]
      },
      {
        "heading": "Conduite à tenir :",
        "items": [
          "Rester avec la victime",
          "Envoyer quelqu’un à un point de rencontre si nécessaire",
          "Garder le téléphone chargé autant que possible"
        ]
      },
      {
        "heading": "Assurance",
        "items": [
          "0 800 875 875 en France",
          "+33 5 49 77 47 78 depuis l’étranger",
          "sociétaire MAIF 3163163A"
        ]
      }
    ]
  },
